{
  "name": "opencomputer-pr-review-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A GitHub App webhook service that reviews pull requests with OpenComputer Durable Agent Sessions.",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "tsc",
    "bootstrap:agent": "tsx scripts/bootstrap-opencomputer-agent.ts",
    "start": "node dist/src/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "node --import tsx --test test/*.test.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "@opencomputer/sdk": "^0.7.2",
    "hono": "^4.12.26"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
